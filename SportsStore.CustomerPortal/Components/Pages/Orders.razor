@page "/orders"
@rendermode InteractiveServer

@using System.Net.Http.Json

@inject HttpClient Http

<PageTitle>My Orders</PageTitle>

<div class="page-header">
    <h2>My Orders</h2>
    <p>Track your purchases and check the status of each order.</p>
</div>

@if (orders == null)
{
    <div class="content-card">
        <p class="mb-0 text-muted">Loading orders...</p>
    </div>
}
else if (!orders.Any())
{
    <div class="empty-state">
        <h4>No orders found</h4>
        <p class="text-muted mb-0">You have not placed any orders yet.</p>
    </div>
}
else
{
    <div class="table-card">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Total</th>
                        <th>Date</th>
                        <th class="text-end">Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in orders)
                    {
                        <tr>
                            <td class="order-id">@o.Id</td>
                            <td>@o.CustomerEmail</td>
                            <td>
                                <span class="@GetStatusClass(o.Status)">
                                    @GetStatusName(o.Status)
                                </span>
                            </td>
                            <td>€@o.TotalAmount.ToString("0.00")</td>
                            <td>@o.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-primary" href="/orders/@o.Id">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<Order>? orders;

    protected override async Task OnInitializedAsync()
    {
        orders = await Http.GetFromJsonAsync<List<Order>>("api/orders");
    }

    string GetStatusName(int status)
    {
        return status switch
        {
            1 => "Submitted",
            2 => "Inventory Pending",
            3 => "Inventory Confirmed",
            4 => "Inventory Failed",
            5 => "Payment Pending",
            6 => "Payment Approved",
            7 => "Payment Failed",
            8 => "Shipping Pending",
            9 => "Shipping Created",
            10 => "Completed",
            11 => "Failed",
            _ => "Unknown"
        };
    }

    string GetStatusClass(int status)
    {
        return status switch
        {
            10 => "badge bg-success",
            11 => "badge bg-danger",
            5 or 8 => "badge bg-warning text-dark",
            _ => "badge bg-info text-dark"
        };
    }

    public class Order
    {
        public Guid Id { get; set; }
        public string CustomerEmail { get; set; } = "";
        public int Status { get; set; }
        public decimal TotalAmount { get; set; }
        public DateTime CreatedAtUtc { get; set; }
    }
}