@page "/products"
@rendermode InteractiveServer

@using SportsStore.CustomerPortal.Services
@using SportsStore.CustomerPortal.Models

@inject HttpClient Http
@inject CartService CartService

<h3>Products</h3>

@if (products == null)
{
    <p>Loading...</p>
}
else
{
    <ul>
        @foreach (var p in products)
        {
            <li>
                <b>@p.Name</b> - €@p.Price (Stock: @p.StockQuantity)
                <button class="btn btn-primary btn-sm ms-2" @onclick="() => AddToCart(p)">Add</button>
            </li>
        }
    </ul>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert alert-success mt-3">
            @message
        </div>
    }
}

@code {
    private List<Product>? products;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        products = await Http.GetFromJsonAsync<List<Product>>("api/products");
    }

    private void AddToCart(Product p)
    {
        CartService.AddToCart(new CartItem
        {
            ProductId = p.Id,
            ProductName = p.Name,
            Price = p.Price,
            Quantity = 1
        });

        message = $"{p.Name} added to cart!";
    }

    public class Product
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public int StockQuantity { get; set; }
    }
}