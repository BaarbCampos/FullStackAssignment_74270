@page "/products"
@rendermode InteractiveServer

@using System.Net.Http.Json
@using SportsStore.CustomerPortal.Services
@using SportsStore.CustomerPortal.Models

@inject HttpClient Http
@inject CartService CartService
@inject NavigationManager Navigation

<PageTitle>Products</PageTitle>

<div class="page-header">
    <h2>Products</h2>
    <p>Choose your sports items and add them to your cart.</p>
</div>

@if (products == null)
{
    <div class="content-card">
        <p class="mb-0 text-muted">Loading products...</p>
    </div>
}
else if (!products.Any())
{
    <div class="empty-state">
        <h4>No products found</h4>
        <p class="text-muted mb-0">There are no products available right now.</p>
    </div>
}
else
{
    <div class="product-grid">
        @foreach (var p in products)
        {
            <div class="product-card">
                <div>
                    <h4>@p.Name</h4>
                    <div class="product-price">€@p.Price.ToString("0.00")</div>
                    <div class="product-stock @(p.StockQuantity > 0 ? "in-stock" : "out-of-stock")">
                        @(p.StockQuantity > 0 ? $"In stock: {p.StockQuantity}" : "Out of stock")
                    </div>
                </div>

                <button class="btn btn-primary w-100"
                        disabled="@(p.StockQuantity <= 0)"
                        @onclick="() => AddToCart(p)">
                    @(p.StockQuantity > 0 ? "Add to Cart" : "Unavailable")
                </button>
            </div>
        }
    </div>
}

@code {
    private List<Product>? products;

    protected override async Task OnInitializedAsync()
    {
        products = await Http.GetFromJsonAsync<List<Product>>("api/products");
    }

    private void AddToCart(Product p)
    {
        CartService.AddToCart(new CartItem
        {
            ProductId = p.Id,
            ProductName = p.Name,
            Price = p.Price,
            Quantity = 1
        });

        Navigation.NavigateTo("/cart");
    }

    public class Product
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public int StockQuantity { get; set; }
    }
}