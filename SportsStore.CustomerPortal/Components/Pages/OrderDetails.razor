@page "/orders/{Id:guid}"
@rendermode InteractiveServer

@using System.Net.Http.Json

@inject HttpClient Http

<PageTitle>Order Details</PageTitle>

<div class="page-header">
    <h2>Order Details</h2>
    <p>Detailed information about your selected order.</p>
</div>

@if (order == null)
{
    <div class="content-card">
        <p class="mb-0 text-muted">Loading order details...</p>
    </div>
}
else
{
    <div class="content-card">
        <div class="order-info-row">
            <div class="order-info-item">
                <span>Order ID</span>
                <strong>@order.Id</strong>
            </div>

            <div class="order-info-item">
                <span>Email</span>
                <strong>@order.CustomerEmail</strong>
            </div>

            <div class="order-info-item">
                <span>Status</span>
                <strong>
                    <span class="@GetStatusClass(order.Status)">
                        @GetStatusName(order.Status)
                    </span>
                </strong>
            </div>

            <div class="order-info-item">
                <span>Total</span>
                <strong>€@order.TotalAmount.ToString("0.00")</strong>
            </div>

            <div class="order-info-item">
                <span>Date</span>
                <strong>@order.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
            </div>
        </div>
    </div>

    <div class="table-card">
        <h4 class="mb-3">Items</h4>

        @if (order.Items == null || !order.Items.Any())
        {
            <p class="text-muted mb-0">No items found for this order.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Unit Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in order.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.Quantity</td>
                                <td>€@item.UnitPrice.ToString("0.00")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private OrderDetailsDto? order;

    protected override async Task OnInitializedAsync()
    {
        order = await Http.GetFromJsonAsync<OrderDetailsDto>($"api/orders/{Id}");
    }

    string GetStatusName(int status)
    {
        return status switch
        {
            1 => "Submitted",
            2 => "Inventory Pending",
            3 => "Inventory Confirmed",
            4 => "Inventory Failed",
            5 => "Payment Pending",
            6 => "Payment Approved",
            7 => "Payment Failed",
            8 => "Shipping Pending",
            9 => "Shipping Created",
            10 => "Completed",
            11 => "Failed",
            _ => "Unknown"
        };
    }

    string GetStatusClass(int status)
    {
        return status switch
        {
            10 => "badge bg-success",
            11 => "badge bg-danger",
            5 or 8 => "badge bg-warning text-dark",
            _ => "badge bg-info text-dark"
        };
    }

    public class OrderDetailsDto
    {
        public Guid Id { get; set; }
        public string CustomerEmail { get; set; } = "";
        public int Status { get; set; }
        public decimal TotalAmount { get; set; }
        public DateTime CreatedAtUtc { get; set; }
        public List<OrderItemDto> Items { get; set; } = new();
    }

    public class OrderItemDto
    {
        public int Id { get; set; }
        public int ProductId { get; set; }
        public string ProductName { get; set; } = "";
        public int Quantity { get; set; }
        public decimal UnitPrice { get; set; }
    }
}