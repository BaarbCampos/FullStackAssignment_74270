@page "/cart"
@rendermode InteractiveServer

@using System.Net.Http.Json
@using SportsStore.CustomerPortal.Models
@using SportsStore.CustomerPortal.Services

@inject CartService CartService
@inject HttpClient Http

<PageTitle>Cart</PageTitle>

<div class="page-header">
    <h2>Your Cart</h2>
    <p>Review your selected items before completing your purchase.</p>
</div>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert @(isSuccess ? "alert-success" : "alert-warning") mb-4">
        @message
    </div>
}

@if (!CartService.GetItems().Any())
{
    <div class="empty-state">
        <h4>Your cart is empty</h4>
        <p class="text-muted">Add some products to continue shopping.</p>
        <a class="btn btn-primary mt-2" href="/products">Browse Products</a>
    </div>
}
else
{
    <div class="table-card">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th>Price</th>
                        <th>Total</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in CartService.GetItems())
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.Quantity</td>
                            <td>€@item.Price.ToString("0.00")</td>
                            <td>€@((item.Price * item.Quantity).ToString("0.00"))</td>
                            <td class="text-end">
                                <button class="btn btn-danger btn-sm" @onclick="() => Remove(item.ProductId)">
                                    Remove
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="summary-box">
        <h4 class="mb-3">Order Summary</h4>
        <h3 class="mb-4">Total: €@CartService.GetTotal().ToString("0.00")</h3>

        <div class="mb-3">
            <label class="form-label">Customer Email</label>
            <input class="form-control" @bind="customerEmail" placeholder="Enter your email" />
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-success" @onclick="Checkout">Checkout</button>
            <button class="btn btn-secondary" @onclick="ClearCart">Clear Cart</button>
            <a class="btn btn-outline-primary" href="/products">Continue Shopping</a>
        </div>
    </div>
}

@code {
    private string customerEmail = string.Empty;
    private string message = string.Empty;
    private bool isSuccess = false;

    private void Remove(int productId)
    {
        CartService.Remove(productId);
    }

    private void ClearCart()
    {
        CartService.Clear();
        message = "Cart cleared.";
        isSuccess = false;
    }

    private async Task Checkout()
    {
        if (!CartService.GetItems().Any())
        {
            message = "Your cart is empty.";
            isSuccess = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(customerEmail))
        {
            message = "Please enter your email.";
            isSuccess = false;
            return;
        }

        var request = new CheckoutRequest
        {
            CustomerEmail = customerEmail,
            Items = CartService.GetItems()
                .Select(item => new CheckoutItem
                {
                    ProductId = item.ProductId,
                    Quantity = item.Quantity
                })
                .ToList()
        };

        var response = await Http.PostAsJsonAsync("api/Orders/checkout", request);

        if (response.IsSuccessStatusCode)
        {
            CartService.Clear();
            customerEmail = string.Empty;
            message = "Order placed successfully! Your cart has been cleared.";
            isSuccess = true;
        }
        else
        {
            message = $"Checkout failed: {response.StatusCode}";
            isSuccess = false;
        }
    }
}